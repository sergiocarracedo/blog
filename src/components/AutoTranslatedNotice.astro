---
import { getLangFromUrl, languageNames, useTranslations, type Locale } from '@/i18n';
import { Icon } from 'astro-icon/components';

interface Props {
  /**
   * Original language of the post
   */
  originalLang: Locale;
  /**
   * URL to the original post
   */
  originalUrl: string;
  /**
   * Current language override
   */
  lang?: Locale;
}

const { originalLang, originalUrl, lang: propLang } = Astro.props;
const currentLang = propLang ?? getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);

// Get the name of the original language in the current language
const originalLangName = languageNames[currentLang][originalLang];
---

<aside
  class="auto-translated-notice mb-6 p-4 rounded-lg bg-amber-100 dark:bg-amber-900/30 border border-amber-300 dark:border-amber-700"
>
  <div class="flex items-center gap-3 justify-start">
    <Icon
      name="outline/arrow-right-left-outline"
      class="w-5 h-5 text-amber-600 dark:text-amber-400 flex-shrink-0 mt-0.5"
    />
    <p class="text-sm text-amber-800 dark:text-amber-200 flex-1 flex flex-row items-center gap-3">
      <span class="font-semibold">{t('translation.auto', { lang: originalLangName })} </span>
      <a
        href={originalUrl}
        class="inline-flex items-center gap-1 text-sm text-amber-700 dark:text-amber-300 hover:text-amber-900 dark:hover:text-amber-100 underline underline-offset-2"
      >
        <Icon name="outline/arrow-right-outline" class="w-3 h-3" />
        {t('translation.viewOriginal')}
      </a>
    </p>
  </div>
</aside>
