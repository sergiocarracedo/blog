---
import { getLangFromUrl, getLocalizedDate } from '@/i18n';

interface Props {
  date: Date;
  class?: string;
  prepend?: string | Astro.JSX.Element;
  postId?: string;
  lang?: 'en' | 'es';
}

const { date, postId, lang: propLang } = Astro.props;
const lang = propLang ?? getLangFromUrl(Astro.url);
---

<time
  datetime={date.toISOString()}
  class:list={[`flex items-center gap-2`, Astro.props.class]}
  transition:name={`post-date-${postId}`}
>
  {Astro.props.prepend && <span class="prepend">{Astro.props.prepend}</span>}
  {getLocalizedDate(date, lang)}
</time>
