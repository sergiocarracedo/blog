---
import type { Page } from 'astro';
import { getLangFromUrl, useTranslations } from '@/i18n';

type Props = {
  page: Page<unknown>;
  urlPattern: string;
  lang?: 'en' | 'es';
};

const { page, urlPattern, lang: propLang } = Astro.props;
const lang = propLang ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Calculate a window of up to 5 pages centered on the current page
let start = Math.max(1, page.currentPage - 2);
let end = Math.min(page.lastPage, start + 4);
if (end - start < 4) {
  start = Math.max(1, end - 4);
}
const paginationList = Array.from({ length: end - start + 1 }, (_, i) => start + i);

const getPage = (num: number) => {
  return urlPattern.replace('{}', num.toString());
};
---

<nav aria-label={t('a11y.pages')} class="wrapper bg-secondary-light p-4 backdrop-blur-xs m-4 rounded-lg">
  <ul class="flex items-center justify-center gap-1 flex-wrap max-w-[800px] mx-auto">
    {
      page.url.first && page.url.first !== page.url.current && (
        <li>
          <a href={page.url.first} class="pagination-link" aria-label={t('pagination.first')}>
            <span aria-hidden="true">««</span>
          </a>
        </li>
      )
    }

    {
      page.url.prev && (
        <li>
          <a href={page.url.prev} class="pagination-link" aria-label={t('pagination.previous')}>
            <span aria-hidden="true">«</span>
          </a>
        </li>
      )
    }

    {
      paginationList.map((num) => (
        <li>
          {page.currentPage === num ? (
            <span class="pagination-link parallelogram-mask bg-primary text-white">{num}</span>
          ) : (
            <a
              href={`${getPage(num)}`}
              class={`pagination-link ${page.currentPage === num ? 'pagination__item--active' : ''}`}
              aria-label={t('pagination.goToPage', { num: num.toString() })}
            >
              {num}
            </a>
          )}
        </li>
      ))
    }

    {
      page.url.next && (
        <li>
          <a href={page.url.next} class="pagination-link" aria-label={t('pagination.next')}>
            <span aria-hidden="true">»</span>
          </a>
        </li>
      )
    }

    {
      page.url.last && page.url.last !== page.url.current && (
        <li>
          <a href={page.url.last} class="pagination-link" aria-label={t('pagination.last')}>
            <span aria-hidden="true">»»</span>
          </a>
        </li>
      )
    }
  </ul>
</nav>
