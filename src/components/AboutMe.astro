---
import {
  SITE_AUTHOR,
  SITE_AUTHOR_IMG,
} from '../consts';
import { getLangFromUrl, useTranslations } from '@/i18n';

interface Props {
  class?: string;
  lang?: 'en' | 'es';
}
const { class: className, lang: propLang } = Astro.props;
const lang = propLang ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div class={`color-primary ${className}`}>
  <div class="mb-3">
    <img
      alt={SITE_AUTHOR}
      height="180"
      src={SITE_AUTHOR_IMG}
      width="180"
      class="w-20 h-20 rounded-full border-5 border-primary border-solid"
    />
  </div>
  <h1 class="mb-2 font-impact font-bold text-2xl md:text-4xl">{SITE_AUTHOR}</h1>
  <h2 class="mb-1 text-xl font-normal">
    {t('site.authorPosition')}
  </h2>
  <h3 class="text-lg italic font-normal">
    {t('site.authorDescription')}
  </h3>
</div>
