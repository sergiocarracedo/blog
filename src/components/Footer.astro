---
import AboutMe from './AboutMe.astro';
import SocialLinks from './SocialLinks.astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '@/i18n';

interface Props {
  lang?: 'en' | 'es';
}

const { lang: propLang } = Astro.props;
const lang = propLang ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const today = new Date();
---

<footer
  class="pt-8 pb-10 text-gray-700 dark:text-gray-300 background-paper-secondary dark:bg-none dark:bg-primary-700 border-t border-primary dark:border-secondary border-t-6 border-solid wrapper rounded-xl mb-3"
>
  <div class="flex flex-wrap items-center justify-between gap-4 text-md">
    <div>
      <AboutMe lang={lang} />
      <div class="mt-2 text-sm">
        {t('footer.copyright', { year: today.getFullYear().toString() })}
      </div>
      <div class="mt-2 text-sm">
        <a class="text-primary dark:text-secondary link" href={translatePath('/blog/stats')}>{t('footer.blogStats')}</a>
        <span class="mx-2 opacity-50">•</span>
        <a class="text-primary dark:text-secondary link" href={translatePath('/newsletter/subscribe')}>{t('footer.newsletter')}</a>
      </div>
    </div>
    <SocialLinks />
  </div>
</footer>
