---
import { Image } from 'astro:assets';
import { SITE_TITLE } from '../consts';
import MenuMenu from './menu/Menu.astro';
import MenuOverlay from './menu/MenuOverlay.astro';
import ThemeToggle from './ThemeToggle.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { getLangFromUrl, useTranslatedPath, type Locale } from '@/i18n';

interface Props {
  lang?: Locale;
  translations?: Partial<Record<Locale, string>>;
}

const { lang: propLang, translations } = Astro.props;
const lang = propLang ?? getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);
---

<header
  id="site-header"
  class="sticky top-0 z-50 backdrop-blur-xs bg-secondary/40 dark:bg-primary-700 mb-6 md:mb-15 transition-all duration-500 max-w-full mx-auto print:static"
>
  <nav class="flex gap-4 p-4 items-center justify-between wrapper">
    <h2 class="text-sm md:text-xl min-w-0 truncate">
      <a href={translatePath('/')} class="flex items-center min-w-0">
        <Image
          src="/i/sergiocarracedo.jpg"
          alt="Image of Sergio Carracedo, the blog author"
          width={50}
          height={50}
          class="inline-block mr-2 rounded-full border-solid border-primary dark:border-secondary border-4 w-11 h-11 md:w-13 md:h-13 flex-shrink-0"
        />
        <span class="truncate">{SITE_TITLE}</span>
      </a>
    </h2>

    <div class="internal-links flex items-center gap-2">
      <LanguageSwitcher lang={lang} translations={translations} size="sm" />
      <ThemeToggle />
      <MenuMenu lang={lang} />
    </div>
  </nav>
</header>

<MenuOverlay lang={lang} />

<script>
  const onTopClasses = [
    'max-w-[900px]',
    'bg-secondary/40',
    'md:top-6',
    'backdrop-blur-none',
    'rounded-lg',
  ];
  const scrolledClasses = [
    'max-w-full',
    'bg-white/40',
    'dark:bg-primary-600',
    'backdrop-blur-xs',
    'top-0',
  ];

  function initHeaderScroll() {
    const header = document.getElementById('site-header');
    if (!header) return;

    const onScroll = () => {
      if (window.scrollY === 0) {
        header.classList.add(...onTopClasses);
        header.classList.remove(...scrolledClasses);
      } else {
        header.classList.remove(...onTopClasses);
        header.classList.add(...scrolledClasses);
      }
    };

    window.addEventListener('scroll', onScroll);
    onScroll(); // Initial check
  }

  // Run on first load
  initHeaderScroll();

  // Re-run after every View Transition navigation
  document.addEventListener('astro:after-swap', initHeaderScroll);
</script>
