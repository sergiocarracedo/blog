---
// Import the main.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import { SITE_AUTHOR, SITE_DESCRIPTION, SITE_TITLE, SITE_URL } from '../consts';
import '../styles/tailwind.css';

import copyCodeUrl from '../scripts/copy-code.ts?url';

import { ClientRouter } from 'astro:transitions';
import { 
  getLangFromUrl, 
  useTranslations, 
  getAlternateLocaleUrls,
  type Locale 
} from '@/i18n';

export interface Meta {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article' | 'video' | 'music';
  canonical?: string;
  keywords?: string[];
  robots?: string;
  author?: string;
  date?: string;
}

interface Props {
  meta: Meta;
  lang?: Locale;
  hreflangOverride?: Record<string, string>;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { meta: metaProp, lang: propLang, hreflangOverride } = Astro.props;
const lang = propLang ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Get alternate locale URLs for hreflang tags
const alternateUrls = hreflangOverride ?? getAlternateLocaleUrls(Astro.url.pathname, SITE_URL);

const meta = {
  title: SITE_TITLE,
  description: t('site.description'),
  type: 'website',
  canonical: canonicalURL.toString(),
  keywords: ['web development', 'programming', 'technology'],
  robots: 'index, follow',
  ...metaProp,
};

const image = meta.image || '/i/sergiocarracedo-og.png';
---

<!-- Theme initialization (prevents flash of wrong theme) -->
<script is:inline>
  function applyTheme() {
    const stored = localStorage.getItem('theme');
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const theme = stored || (prefersDark ? 'dark' : 'light');
    
    console.log('[BaseHead] Applying theme:', theme, 'from storage:', stored);
    
    if (theme === 'dark') {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  }
  
  // Apply theme immediately
  applyTheme();
  
  // Re-apply theme after view transitions
  document.addEventListener('astro:after-swap', applyTheme);
</script>

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
  rel="alternate"
  type="application/rss+xml"
  title={`${SITE_TITLE} | ${lang === 'es' ? 'ES' : 'EN'}`}
  href={new URL(lang === 'es' ? 'es/rss.xml' : 'rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Font preloads -->
<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />
<link rel="preload" href="/fonts/NotoSans-Regular.woff2" as="font" type="font/woff2" crossorigin />
<link rel="preload" href="/fonts/NotoSans-Bold.woff2" as="font" type="font/woff2" crossorigin />
<link
  rel="preload"
  as="image"
  href="/i/sergiocarracedo-alt.webp"
  imagesrcset="/i/sergiocarracedo-alt.webp"
  fetchpriority="high"
/>

<!-- Canonical URL -->
<link rel="canonical" href={meta.canonical || Astro.url} />

<!-- hreflang tags for i18n -->
<link rel="alternate" hreflang="en" href={alternateUrls.en} />
<link rel="alternate" hreflang="es" href={alternateUrls.es} />
<link rel="alternate" hreflang="x-default" href={alternateUrls['x-default']} />

<!-- Primary Meta Tags -->
<title>{SITE_TITLE} | {meta.title}</title>
<meta name="title" content={meta.title} />
<meta name="description" content={meta.description} />
{meta.keywords && <meta name="keywords" content={meta.keywords.join(', ')} />}
<meta name="author" content={meta.author ?? SITE_AUTHOR} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={meta.type ?? 'website'} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={meta.title} />
<meta property="og:description" content={meta.description} />
<meta property="og:image" content={new URL(image, Astro.url)} />
<meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
<meta property="og:locale:alternate" content={lang === 'es' ? 'en_US' : 'es_ES'} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={meta.title} />
<meta property="twitter:description" content={meta.description} />
<meta property="twitter:image" content={new URL(image, Astro.url)} />

<!-- Favicon -->
<link href="/apple-touch-icon.png" rel="apple-touch-icon" sizes="180x180" />
<link href="/favicon-32x32.png" rel="icon" sizes="32x32" type="image/png" />
<link href="/favicon-16x16.png" rel="icon" sizes="16x16" type="image/png" />

<!-- Aditional metatags -->
<link href="/site.webmanifest" rel="manifest" />

<meta content="#213b4a" name="msapplication-TileColor" />
<meta content="#213b4a" name="theme-color" />

<ClientRouter />

<script type="module" src={copyCodeUrl}></script>
