---
import { Icon } from 'astro-icon/components';
import {
  languages,
  getLangFromUrl,
  getAlternateLocalePath,
  useTranslations,
  type Locale,
} from '@/i18n';

interface Props {
  /**
   * Optional translations available for current page
   * If provided, will link to the specific translated page
   */
  translations?: Partial<Record<Locale, string>>;
  /**
   * Current language override
   */
  lang?: Locale;
  /**
   * Size variant
   */
  size?: 'sm' | 'md';
}

const { translations, lang: propLang, size = 'md' } = Astro.props;
const currentLang = propLang ?? getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);

// Get alternate language
const alternateLang: Locale = currentLang === 'en' ? 'es' : 'en';

// Determine URL for alternate language
const alternateUrl = translations?.[alternateLang] 
  ? translations[alternateLang] 
  : getAlternateLocalePath(Astro.url.pathname, alternateLang);

const sizeClasses = {
  sm: 'text-xs px-2 py-1',
  md: 'text-sm px-3 py-1.5',
};
---

<div class="language-switcher flex items-center gap-1">
  <a
    href={alternateUrl}
    class:list={[
      'flex items-center gap-1 rounded-full border border-current',
      'text-primary dark:text-secondary',
      'hover:bg-primary hover:text-white dark:hover:bg-secondary dark:hover:text-primary',
      'transition-colors duration-200',
      sizeClasses[size],
    ]}
    title={t('lang.switchTo', { lang: languages[alternateLang] })}
    aria-label={t('lang.switchTo', { lang: languages[alternateLang] })}
  >
    <Icon name="outline/arrow-right-left-outline" class="w-4 h-4" />
    <span class="uppercase font-semibold">{alternateLang}</span>
  </a>
</div>

<style>
  .language-switcher {
    /* Ensure it doesn't grow/shrink unexpectedly */
    flex-shrink: 0;
  }
</style>
