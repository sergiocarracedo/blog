---
import type { CollectionKey } from 'astro:content';
import { getLocalizedPosts } from '@/utils/getLocalizedPosts';
import PostMiniNav from './PostMiniNav.astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '@/i18n';

interface Props {
  collection?: CollectionKey;
  id: string;
  lang?: 'en' | 'es';
}

const { collection = 'blog', id, lang: propLang } = Astro.props;
const lang = propLang ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const posts = collection === 'blog' ? await getLocalizedPosts(lang) : [];

const post = posts.find((p) => p.id === id);
if (!post) {
  return;
}

const currentIndex = posts.findIndex((p) => p.id === id);
const nextIndex = currentIndex + 1;
const prevIndex = currentIndex - 1;
const nextPost = posts[nextIndex];
const prevPost = posts[prevIndex];
---

<div class="flex gap-4 flex-wrap space-between w-full">
  {
    nextPost ? (
      <div class="order-1 grow-1">
        <PostMiniNav post={nextPost} direction="next" lang={lang} />
      </div>
    ) : (
      <div class="order-1 grow-1 w-[200px]" aria-hidden="true" />
    )
  }

  <div
    class="flex-1 flex justify-center items-center min-w-40 py-10 order-10 sm:order-4 w-full sm:w-auto basis-full sm:basis-auto"
  >
    <a class="btn-outlined" href={translatePath('/blog')} title={t('post.allPosts')}> {t('post.allPosts')} </a>
  </div>
  {
    prevPost ? (
      <div class="order-5 grow-1">
        <PostMiniNav post={prevPost} direction="prev" lang={lang} class="order-6 justify-self-end" />
      </div>
    ) : (
      <div class="order-5 grow-1 w-[200px]" aria-hidden="true" />
    )
  }
</div>
