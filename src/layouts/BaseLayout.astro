---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import NewsletterToast from '../components/NewsletterToast.astro';
import NewsletterSuccessToast from '../components/NewsletterSuccessToast.astro';

import { DISQUS, GA } from '../consts';
import { getLangFromUrl, type Locale } from '@/i18n';

interface Props {
  meta: {
    title: string;
    description?: string;
    image?: string;
    canonicalUrl?: string;
    canonical?: string;
  };
  lang?: Locale;
  hreflangOverride?: Record<string, string>;
  translations?: Partial<Record<Locale, string>>;
}

const { meta, lang: propLang, hreflangOverride, translations } = Astro.props;
const lang = propLang ?? getLangFromUrl(Astro.url);
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead meta={meta} lang={lang} hreflangOverride={hreflangOverride} />
  </head>
  <body class="max-w-full overflow-x-hidden">
    <Header lang={lang} translations={translations} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
    <NewsletterToast lang={lang} />
    <NewsletterSuccessToast />

    <script
      async
      data-category="analytics"
      data-service="ga4"
      data-src={`https://www.googletagmanager.com/gtag/js?id=${GA}`}></script>

    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        window.dataLayer.push(arguments);
      }
      gtag('js', new Date());

      gtag('config', 'G-87X78TXEGE');
    </script>

    <script
      async
      data-category="analytics"
      data-service="disqus"
      data-src={`https://${DISQUS}/embed.js`}></script>
  </body>
</html>
