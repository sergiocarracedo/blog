---
import AboutMe from '@/components/about/AboutMe.astro';
import BaseLayout from './BaseLayout.astro';
import { getLangFromUrl, type Locale } from '@/i18n';

const { frontmatter } = Astro.props;
const lang: Locale = (frontmatter.lang as Locale) ?? getLangFromUrl(Astro.url);

const meta = {
  title: frontmatter.title || 'Page',
  description: frontmatter.description || '',
  keywords: frontmatter.keywords || [],
  subtitle: frontmatter.subtitle || '',
};
---

<BaseLayout meta={meta} lang={lang}>
  <div class="wrapper-no-padding">
    <AboutMe lang={lang} />
    <div class="prose p-6 sm:p-6 lg:p-8">
      <slot />
    </div>
  </div>
</BaseLayout>
