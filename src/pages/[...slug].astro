---
import { enrichBlogPost } from '@/utils/enrichBlogPost';
import { isLocaleFile, getFileLocale, getPostSwitcherUrls, getRoutingSlug } from '@/utils/getLocalizedPosts';
import { type CollectionEntry, getCollection } from 'astro:content';
import PostSingle from '../components/posts/PostSingle.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { truncate } from '../utils/truncate';
import { defaultLocale, type Locale } from '@/i18n';

const lang: Locale = defaultLocale; // English for root paths

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  // EN root serves:
  // 1. Plain index.mdx with lang: en or no lang
  // 2. index.en.mdx (EN translations of ES-original posts)
  // Exclude:
  // - index.es.mdx (served at /es/...)
  // - plain index.mdx with lang: es (legacy, served at /es/...)
  const enPosts = posts.filter((post) => {
    if (isLocaleFile(post)) {
      return getFileLocale(post) === 'en';
    }
    return !post.data.lang || post.data.lang === 'en';
  });

  return enPosts.map((post) => {
    // For locale files (index.en.mdx), the route slug is the frontmatter slug or directory
    const routeSlug = getRoutingSlug(post);
    return {
      params: { slug: routeSlug },
      props: post,
    };
  });
}

type Props = CollectionEntry<'blog'>;

const post = Astro.props;

const enrichedPost = enrichBlogPost(post);
const switcher = await getPostSwitcherUrls(post);

const meta = {
  title: enrichedPost.data.title,
  description: truncate(enrichedPost.excerpt, 180),
  image: enrichedPost.data.heroImage?.src,
  url: enrichedPost.slug,
  date: post.data.pubDate,
  tags: post.data.tags || [],
  type: 'article',
  ...(post.data.canonicalUrl ? { canonical: post.data.canonicalUrl } : {}),
};
---

<BaseLayout meta={meta} lang={lang} translations={switcher}>
  <PostSingle post={post} lang={lang} />
</BaseLayout>
