---
import { enrichBlogPost } from '@/utils/enrichBlogPost';
import { isLocaleFile, getFileLocale, getPostDirectory, getPostSwitcherUrls, getRoutingSlug } from '@/utils/getLocalizedPosts';
import { type CollectionEntry, getCollection } from 'astro:content';
import PostSingle from '@/components/posts/PostSingle.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { truncate } from '@/utils/truncate';
import { type Locale } from '@/i18n';
import { SITE_URL } from '@/consts';

const lang: Locale = 'es';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');

  // Build a set of directories that have a Spanish version (index.es.mdx, index.es.t.mdx, or legacy lang:es index.mdx)
  const hasSpanishVersion = new Set<string>();
  for (const post of allPosts) {
    if (isLocaleFile(post) && getFileLocale(post) === 'es') {
      hasSpanishVersion.add(getPostDirectory(post));
    } else if (!isLocaleFile(post) && post.data.lang === 'es') {
      hasSpanishVersion.add(getPostDirectory(post));
    }
  }

  const paths: {
    params: { slug: string };
    props: { post: CollectionEntry<'blog'>; isFallback: boolean };
  }[] = [];
  const seenSlugs = new Set<string>();

  for (const post of allPosts) {
    // Skip EN-only locale files — served at root only; but also generate /es/ fallback if no ES version
    if (isLocaleFile(post) && getFileLocale(post) === 'en') {
      const dir = getPostDirectory(post);
      if (!hasSpanishVersion.has(dir)) {
        // EN-only post: serve as fallback at /es/{slug}
        const routeSlug = getRoutingSlug(post);
        if (!seenSlugs.has(routeSlug)) {
          seenSlugs.add(routeSlug);
          paths.push({ params: { slug: routeSlug }, props: { post, isFallback: true } });
        }
      }
      continue;
    }

    // index.es.mdx / index.es.t.mdx → served at /es/{slug}
    if (isLocaleFile(post) && getFileLocale(post) === 'es') {
      const routeSlug = getRoutingSlug(post);
      if (!seenSlugs.has(routeSlug)) {
        seenSlugs.add(routeSlug);
        paths.push({ params: { slug: routeSlug }, props: { post, isFallback: false } });
      }
      continue;
    }

    // Plain index.mdx with lang: es (legacy format, before rename) → /es/{post.id}
    if (!isLocaleFile(post) && post.data.lang === 'es') {
      const routeSlug = post.id;
      if (!seenSlugs.has(routeSlug)) {
        seenSlugs.add(routeSlug);
        paths.push({ params: { slug: routeSlug }, props: { post, isFallback: false } });
      }
      continue;
    }

    // Plain index.mdx (EN, no lang) → serve as fallback at /es/{slug}
    // unless this directory already has a Spanish version
    if (!isLocaleFile(post) && (!post.data.lang || post.data.lang === 'en')) {
      const routeSlug = post.id;
      const dir = getPostDirectory(post);
      const isFallback = !hasSpanishVersion.has(dir);
      if (!seenSlugs.has(routeSlug)) {
        seenSlugs.add(routeSlug);
        paths.push({ params: { slug: routeSlug }, props: { post, isFallback } });
      }
    }
  }

  return paths;
}

interface Props {
  post: CollectionEntry<'blog'>;
  isFallback: boolean;
}

const { post, isFallback } = Astro.props;

const enrichedPost = enrichBlogPost(post);
const switcher = await getPostSwitcherUrls(post);

// For fallback pages (English post shown under /es/), canonical points to the EN URL
const canonicalUrl = isFallback
  ? new URL(`/${Astro.params.slug}`, SITE_URL).toString()
  : undefined;

// hreflang: for fallback pages, both EN and ES point to the same EN URL (no ES version)
const hreflangOverride = isFallback
  ? { en: canonicalUrl!, es: canonicalUrl!, 'x-default': canonicalUrl! }
  : undefined;

const meta = {
  title: enrichedPost.data.title,
  description: truncate(enrichedPost.excerpt, 180),
  image: enrichedPost.data.heroImage?.src,
  url: Astro.params.slug,
  date: post.data.pubDate,
  tags: post.data.tags || [],
  type: 'article' as const,
  ...(canonicalUrl ? { canonical: canonicalUrl } : {}),
};
---

<BaseLayout meta={meta} lang={lang} hreflangOverride={hreflangOverride} translations={switcher}>
  <PostSingle post={post} lang={lang} isFallback={isFallback} />
</BaseLayout>
