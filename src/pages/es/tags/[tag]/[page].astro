---
import SectionHeader from '@/components/SectionHeader.astro';
import { createSlug } from '@/utils/createSlug';
import type { CollectionEntry } from 'astro:content';
import Pagination from '@/components/Pagination.astro';
import PostTeaser from '@/components/posts/PostTeaser.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLocalizedPostsByTag, getLocalizedTags } from '@/utils/getLocalizedPosts';
import { useTranslations, type Locale } from '@/i18n';

const lang: Locale = 'es';
const t = useTranslations(lang);

// Represents the params object for your [tag]/[page].astro route
export interface TagPageParams {
  tag: string;
  page: string;
}

// Represents the props you might want to pass to each page
export interface TagPageProps {
  posts: any[];
  tag: string;
}

// Represents a single path object returned by getStaticPaths
export interface StaticPath {
  params: TagPageParams;
  props: TagPageProps;
}

export const getStaticPaths = async ({
  paginate,
}: {
  paginate: (
    items: CollectionEntry<'blog'>[],
    options: { pageSize: number; params: { tag: string } }
  ) => StaticPath[];
}) => {
  const { getLocalizedTags, getLocalizedPostsByTag } = await import('@/utils/getLocalizedPosts');
  const { createSlug } = await import('@/utils/createSlug');
  
  const paths: StaticPath[] = [];
  const tags = await getLocalizedTags('es');
  
  for (const tag of tags) {
    const tagPosts = await getLocalizedPostsByTag('es', tag);
    const slug = createSlug(tag);
    const paginated = paginate(tagPosts, { pageSize: 10, params: { tag: slug } });
    paginated.forEach((page) => {
      paths.push({ ...page, props: { ...page.props, tag } });
    });
  }

  return paths;
};

const { tag: tagSlug } = Astro.params;
const { page, tag } = Astro.props;
const { data: posts } = page;

const filteredPosts = posts.filter((post) => post.data.tags?.includes(tag));

const urlPattern = `/es/tags/${createSlug(tag)}/{}`;
---

<BaseLayout meta={{ title: t('blog.postsWithTag', { tag }), description: t('site.description') }} lang={lang}>
  <section class="wrapper">
    <SectionHeader
      title={t('blog.postsWithTag', { tag })}
      subtitle={`[${filteredPosts.length} post${filteredPosts.length !== 1 ? 's' : ''}]`}
      description={t('site.description')}
      class="mb-6"
    />
    <ul>
      <ul>
        {
          filteredPosts.map((post) => (
            <li>
              <PostTeaser post={post} lang={lang} />
            </li>
          ))
        }
      </ul>
    </ul>
  </section>
  <Pagination page={page} urlPattern={urlPattern} lang={lang} />
</BaseLayout>
