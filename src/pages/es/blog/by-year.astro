---
import SectionHeader from '@/components/SectionHeader.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { enrichBlogPost } from '@/utils/enrichBlogPost';
import { getSlug } from '@/utils/getSlug';
import { getLocalizedPostsByYear } from '@/utils/getLocalizedPosts';
import type { CollectionEntry } from 'astro:content';
import { useTranslations, useTranslatedPath, getLocalizedDate, type Locale } from '@/i18n';

const lang: Locale = 'es';
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const postsByYear = await getLocalizedPostsByYear(lang);

const postsByYearSorted = Array.from(postsByYear.entries()).sort(
  ([yearA], [yearB]) => yearB - yearA
);
---

<BaseLayout meta={{ title: t('nav.byYear'), description: t('site.description') }} lang={lang}>
  <section class="wrapper">
    <div class="flex flex-wrap items-center justify-between gap-4 mb-2">
      <SectionHeader title={t('nav.byYear')} class="mb-1" />
      <a class="text-primary dark:text-secondary link" href={translatePath('/blog/stats')}>{t('footer.blogStats')}</a>
    </div>

    <ul class="flex flex-wrap gap-2 mb-8" role="navigation">
      {
        postsByYearSorted.map(([year, posts]) => (
          <li>
            <a class="text-primary dark:text-secondary link" href={`#${year}`}>
              {year}
            </a>
          </li>
        ))
      }
    </ul>

    {
      postsByYearSorted.map(([year, posts]) => (
        <section class="">
          <h2 class="font-impact font-bold md:text-right md:w-40 mb-4 text-3xl text-primary dark:text-secondary">
            {/* Using the year as an anchor for linking */}
            <a class="anchor" id={year.toString()} />
            {year}
          </h2>
          <ul class="mb-12 list-none">
            {/* Mapping through posts of the current year */}
            {posts.map((post) => {
              const enrichedPost = enrichBlogPost(post);
              return (
                <li class="mb-2 flex gap-5">
                  <span
                    class="md:w-40 text-primary dark:text-secondary md:text-right"
                    transition:name={`post-date-${enrichedPost.sanitizedId}`}
                  >
                    {/* Displaying the publication date */}
                    {getLocalizedDate(post.data.pubDate, lang, { month: 'short', day: 'numeric' })}
                  </span>
                  <a
                    class="flex-1 min-w-0 link font-semibold"
                    href={translatePath(getSlug(post))}
                    transition:name={`post-title-${enrichedPost.sanitizedId}`}
                  >
                    {/* Displaying the post title */}
                    {post.data.title}
                  </a>
                </li>
              );
            })}
          </ul>
        </section>
      ))
    }
  </section>
</BaseLayout>
