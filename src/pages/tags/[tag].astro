---
import { getLocalizedTags } from '@/utils/getLocalizedPosts';
import { createSlug } from '@/utils/createSlug';

export async function getStaticPaths() {
  const { getLocalizedTags } = await import('@/utils/getLocalizedPosts');
  const { createSlug } = await import('@/utils/createSlug');
  
  const { defaultLocale } = await import('@/i18n');
  const tags = await getLocalizedTags(defaultLocale);

  const paths = [];
  for (const tag of tags) {
    const slug = createSlug(tag);
    paths.push({
      params: { tag: slug },
    });
  }
  return paths;
}

const { tag } = Astro.params;
return Astro.rewrite(`/tags/${tag}/1`);
---
