---
import { defaultLocale } from '@/i18n';

export async function getStaticPaths() {
  const { getLocalizedTags } = await import('@/utils/getLocalizedPosts');
  const { createSlug } = await import('@/utils/createSlug');

  const tags = await getLocalizedTags(defaultLocale);
  return tags.map((tag) => ({ params: { tag: createSlug(tag) } }));
}

const { tag } = Astro.params;
return Astro.rewrite(`/en/tags/${tag}/1`);
---
