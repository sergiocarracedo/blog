---
import { getLocalizedTags } from '@/utils/getLocalizedPosts';
import { createSlug } from '@/utils/createSlug';
import { defaultLocale } from '@/i18n';

export const getStaticPaths = async ({ paginate }) => {
  const { getLocalizedTags, getLocalizedPostsByTag } = await import('@/utils/getLocalizedPosts');
  const { createSlug } = await import('@/utils/createSlug');

  const paths = [];
  const tags = await getLocalizedTags(defaultLocale);
  for (const tag of tags) {
    const tagPosts = await getLocalizedPostsByTag(defaultLocale, tag);
    const slug = createSlug(tag);
    const paginated = paginate(tagPosts, { pageSize: 10, params: { tag: slug } });
    paginated.forEach((p) => {
      paths.push({ ...p, props: { ...p.props, tag } });
    });
  }
  return paths;
};

const { tag: tagSlug } = Astro.params;
const { page } = Astro.props;
return Astro.rewrite(`/en/tags/${tagSlug}/${page.currentPage}`);
---
