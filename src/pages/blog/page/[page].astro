---
import { defaultLocale } from '@/i18n';

export async function getStaticPaths({ paginate }) {
  const { getLocalizedPosts } = await import('@/utils/getLocalizedPosts');
  const posts = await getLocalizedPosts(defaultLocale);
  return paginate(posts, { pageSize: 10 });
}

const { page } = Astro.props;
return Astro.rewrite(`/en/blog/page/${page.currentPage}`);
---
