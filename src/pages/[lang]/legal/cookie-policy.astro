---
import SectionHeader from '@/components/SectionHeader.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { locales, type Locale, useTranslations } from '@/i18n';

export function getStaticPaths() {
  return locales.map((l) => ({ params: { lang: l } }));
}

const { lang: langParam } = Astro.params;
const lang = langParam as Locale;
const t = useTranslations(lang);

const meta = {
  title: t('legal.cookiePolicy'),
  description: t('legal.cookie.intro').slice(0, 160),
  keywords: ['legal', 'cookies'],
};
---

<BaseLayout meta={meta} lang={lang}>
  <div class="wrapper">
    <SectionHeader title={meta.title} description={meta.description} />
  </div>

  <div class="wrapper-no-padding">
    <div class="prose p-6 sm:p-6 lg:p-8">
      <p>{t('legal.cookie.intro')}</p>

      <h2>{t('legal.cookie.infoHeading')}</h2>

      <h3>{t('legal.cookie.whatHeading')}</h3>
      <p>{t('legal.cookie.whatBody')}</p>

      <h2>{t('legal.cookie.byDurationHeading')}</h2>

      <h3>{t('legal.cookie.sessionHeading')}</h3>
      <p>{t('legal.cookie.sessionBody')}</p>

      <h3>{t('legal.cookie.persistentHeading')}</h3>
      <p>{t('legal.cookie.persistentBody')}</p>

      <h2>{t('legal.cookie.byControllerHeading')}</h2>

      <h3>{t('legal.cookie.firstPartyHeading')}</h3>
      <p>{t('legal.cookie.firstPartyBody')}</p>

      <h3>{t('legal.cookie.thirdPartyHeading')}</h3>
      <p>{t('legal.cookie.thirdPartyBody')}</p>

      <h2>{t('legal.cookie.byPurposeHeading')}</h2>

      <h3>{t('legal.cookie.technicalHeading')}</h3>
      <p>{t('legal.cookie.technicalBody')}</p>

      <h3>{t('legal.cookie.personalizationHeading')}</h3>
      <p>{t('legal.cookie.personalizationBody')}</p>

      <h3>{t('legal.cookie.analyticsHeading')}</h3>
      <p>{t('legal.cookie.analyticsBody')}</p>

      <h3>{t('legal.cookie.advertisingHeading')}</h3>
      <p>{t('legal.cookie.advertisingBody')}</p>

      <h3>{t('legal.cookie.behavioralHeading')}</h3>
      <p>{t('legal.cookie.behavioralBody')}</p>

      <h2>{t('legal.cookie.usedHeading')}</h2>

      <h3>{t('legal.cookie.firstPartyHeading')}</h3>

      <h5>cookieconsent_status</h5>
      <p>{t('legal.cookie.consentCookieBody')}</p>

      <h3>{t('legal.cookie.thirdPartyHeading')}</h3>

      <h4>Google Analytics</h4>
      <p>
        {t('legal.cookie.gaBody')}
        <a href="https://developers.google.com/analytics/devguides/collection/gajs/cookie-usage">{t('legal.cookie.gaMore')}</a>
      </p>

      <h4>Disqus</h4>
      <p>
        {t('legal.cookie.disqusBody')}
        <a href="https://help.disqus.com/en/articles/1717103-disqus-privacy-policy">{t('legal.cookie.disqusMore')}</a>
      </p>

      <h2>{t('legal.cookie.revokeHeading')}</h2>
      <p>{t('legal.cookie.revokeBody')}</p>

      <h2>{t('legal.cookie.disableHeading')}</h2>
      <ul>
        <li>Internet Explorer: <a href="http://windows.microsoft.com/en-us/windows-vista/block-or-allow-cookies">{t('legal.cookie.disableIE')}</a></li>
        <li>Firefox: <a href="http://support.mozilla.org/en/kb/enable-and-disable-cookies-website-preferences">{t('legal.cookie.disableFF')}</a></li>
        <li>Chrome: <a href="https://support.google.com/chrome/answer/95647?hl=en">{t('legal.cookie.disableChrome')}</a></li>
        <li>Safari: <a href="http://www.apple.com/legal/privacy/en/cookies/">{t('legal.cookie.disableSafari')}</a></li>
      </ul>

      <p>{t('legal.cookie.updated')}</p>
    </div>
  </div>
</BaseLayout>
