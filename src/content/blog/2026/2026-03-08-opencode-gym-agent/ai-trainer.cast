[214.494414, "o", "\u001b[?2026h\u001b[?25l\u001b[2;8H\u001b[38;2;136;136;136m\u001b[48;2;26;26;26m2\u001b[0m\u001b[2;13H\u001b[38;2;242;244;248m\u001b[48;2;26;26;26mob\u001b[0m\u001b[2;16H\u001b[38;2;242;244;248m\u001b[48;2;26;26;26mlity lim\u001b[0m\u001b[2;26H\u001b[38;2;242;244;248m\u001b[48;2;26;26;26mations: \u001b[0m\u001b[2;36H\u001b[38;2;242;244;248m\u001b[48;2;26;26;26mck - avoid heavy overhead movements or exercises that strain neck\u001b[0m\u001b[3;8H\u001b[38;2;136;136;136m\u001b[48;2;26;26;26m3\u001b[0m\u001b[3;10H\u001b[38;2;255;255;255m\u001b[48;2;26;26;26m                                                                                           \u001b[0m\u001b[4;8H\u001b[38;2;136;136;136m\u001b[48;2;26;26;26m4\u001b[0m\u001b[4;10H\u001b[38;2;140;182;255m\u001b[48;2;26;26;26m\u001b[1m## Schedule & Equipment\u001b[0m\u001b[5;8H\u001b[38;2;136;136;136m\u001b[48;2;26;26;26m5\u001b[0m\u001b[5;10H\u001b[38;2;51;177;255m\u001b[48;2;26;26;26m- \u001b[0m\u001b[5;12H\u001b[38;2;242;244;248m\u001b[48;2;26;26;26mTraining days per week: 3-4 (work days)\u001b[0m\u001b[6;8H\u001b[38;2;136;136;136m\u001b[48;2;26;26;26m6\u001b[0m\u001b[6;12H\u001b[38;2;242;244;248m\u001b[48;2;26;26;26mP\u001b[0m\u001b[6;14H\u001b[38;2;242;244;248m\u001b[48;2;26;26;26meferred se\u001b[0m\u001b[6;25H\u001b[38;2;242;244;248m\u001b[48;2;26;26;26msion\u001b[0m\u001b[6;30H\u001b[38;2;242;244;248m\u001b[48;2;26;26;26mduration:\u001b[0m\u001b[6;40H\u001b[38;2;242;244;248m\u001b[48;2;26;26;26m1 hour\u001b[0m\u001b[6;46H\u001b[38;2;255;255;255m\u001b[48;2;26;26;26m     \u001b[0m\u001b[7;8H\u001b[38;2;136;136;136m\u001b[48;2;26;26;26m7\u001b[0m\u001b[7;12H\u001b[38;2;242;244;248m\u001b[48;2;26;26;26mEquipment\u001b[0m\u001b[7;22H\u001b[38;2;242;244;248m\u001b[48;2;26;26;26maccess:\u001b[0m\u001b[7;30H\u001b[38;2;242;244;248m\u001b[48;2;26;26;26mgym + home (b\u001b[0m\u001b[7;44H\u001b[38;2;242;244;248m\u001b[48;2;26;26;26mdyweight only)\u001b[0m\u001b[8;8H\u001b[38;2;136;136;136m\u001b[48;2;26;26;26m8\u001b[0m\u001b[8;10H\u001b[38;2;255;255;255m\u001b[48;2;26;26;26m                                                \u001b[0m\u001b[9;7H\u001b[38;2;255;255;255m\u001b[48;2;26;26;26m  \u001b[0m\u001b[10;3H\u001b[38;2;255;255;255m\u001b[48;2;22;22;22m                                                                                                                                            \u001b[0m\u001b[11;3H\u001b[38;2;30;30;30m\u001b[48;2;22;22;22m┃\u001b[0m\u001b[11;6H\u001b[38;2;128;102;169m\u001b[48;2;22;22;22m\u001b[3mThinking:\u001b[0m\u001b[11;15H\u001b[38;2;161;162;165m\u001b[48;2;22;22;22m Good, I've updated the profile. Now I need to get more details about the neck injury to give appropriate recommendations. Also,\u001b[0m\u001b[12;6H\u001b[38;2;161;162;165m\u001b[48;2;22;22;22m I should\u001b[0m\u001b[12;16H\u001b[38;2;161;162;165m\u001b[48;2;22;22;22mask about goals. Le\u001b[0m\u001b[12;36H\u001b[38;2;161;162;165m\u001b[48;2;22;22;22m me ask about the\u001b[0m\u001b[12;56H\u001b[38;2;161;162;165m\u001b[48;2;22;22;22mck\u001b[0m\u001b[12;59H\u001b[38;2;161;162;165m\u001b[48;2;22;22;22minjury\u001b[0m\u001b[12;66H\u001b[38;2;161;162;165m\u001b[48;2;22;22;22mspecifics and then\u001b[0m\u001b[12;85H\u001b[38;2;161;162;165m\u001b[48;2;22;22;22mmove to goals.\u001b[0m\u001b[12;99H\u001b[38;2;255;255;255m\u001b[48;2;22;22;22m                                            \u001b[0m\u001b[13;3H\u001b[38;2;255;255;255m\u001b[48;2;22;22;22m \u001b[0m\u001b[13;6H\u001b[38;2;255;255;255m\u001b[48;2;22;22;22m                                                                                             \u001b[0m\u001b[14;6H\u001b[38;2;242;244;248m\u001b[48;2;22;22;22mThanks for sharing, Sergio! I've got your profile set up.\u001b[0m\u001b[15;6H\u001b[38;2;255;255;255m\u001b[48;2;22;22;22m                                                         \u001b[0m\u001b[16;6H\u001b[38;2;242;244;248m\u001b[48;2;22;22;22mA couple of quick questions about your neck injury:\u001b[0m\u001b[17;6H\u001b[38;2;51;177;255m\u001b[48;2;22;22;22m- \u001b[0m\u001b[17;8H\u001b[38;2;255;255;255m\u001b[48;2;22;22;22m\u001b[1mWhat caused it?\u001b[0m\u001b[17;24H\u001b[38;2;242;244;248m\u001b[48;2;22;22;22m(e.g., acciden\u001b[0m\u001b[17;39H\u001b[38;2;242;244;248m\u001b[48;2;22;22;22m, ch\u001b[0m\u001b[17;44H\u001b[38;2;242;244;248m\u001b[48;2;22;22;22mo\u001b[0m\u001b[17;46H\u001b[38;2;242;244;248m\u001b[48;2;22;22;22mi\u001b[0m\u001b[17;48H\u001b[38;2;242;244;248m\u001b[48;2;22;22;22m issue, herniated disc, etc.)\u001b[0m\u001b[18;13H\u001b[38;2;255;255;255m\u001b[48;2;22;22;22m\u001b[1mmovements or exercises make it worse?\u001b[0m\u001b[18;50H\u001b[38;2;242;244;248m\u001b[48;2;22;22;22m (e.g., overh\u001b[0m\u001b[18;64H\u001b[38;2;242;244;248m\u001b[48;2;22;22;22mad pressing, chin-ups, certain neck positions)\u001b[0m\u001b[19;6H\u001b[38;2;255;255;255m\u001b[48;2;22;22;22m                                                                                                        \u001b[0m\u001b[20;6H\u001b[38;2;242;244;248m\u001b[48;2;22;22;22mThis will help me suggest exercises that are safe for you.\u001b[0m\u001b[21;6H\u001b[38;2;255;255;255m\u001b[48;2;22;22;22m                                                          \u001b[0m\u001b[22;6H\u001b[38;2;169"]
