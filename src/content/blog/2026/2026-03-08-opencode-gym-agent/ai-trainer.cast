[34.032421, "o", "\u001b[?2026h\u001b[?25l\u001b[2;3H\u001b[38;2;255;255;255m\u001b[48;2;22;22;22m \u001b[0m\u001b[2;6H\u001b[38;2;242;244;248m\u001b[48;2;22;22;22mI’m an AI fitness assistant. My guidance is informational only and not medical advice. If you have health concerns, consult a qualified \u001b[0m\u001b[3;6H\u001b[38;2;242;244;248m\u001b[48;2;22;22;22mhealthcare professional.\u001b[0m\u001b[4;6H\u001b[38;2;255;255;255m\u001b[48;2;22;22;22m                                                                                                                                        \u001b[0m\u001b[5;6H\u001b[38;2;242;244;248m\u001b[48;2;22;22;22mHi! Let m\u001b[0m\u001b[5;17H\u001b[38;2;242;244;248m\u001b[48;2;22;22;22mcheck your setup and see what we're working with.\u001b[0m\u001b[7;3H\u001b[38;2;22;22;22m\u001b[48;2;26;26;26m┃\u001b[0m\u001b[7;4H\u001b[38;2;255;255;255m\u001b[48;2;26;26;26m                                                                                                                                           \u001b[0m\u001b[8;3H\u001b[38;2;22;22;22m\u001b[48;2;26;26;26m┃\u001b[0m\u001b[8;4H\u001b[38;2;255;255;255m\u001b[48;2;26;26;26m  \u001b[0m\u001b[8;6H\u001b[38;2;125;132;143m\u001b[48;2;26;26;26m# Check if Hevy API key exists\u001b[0m\u001b[8;36H\u001b[38;2;255;255;255m\u001b[48;2;26;26;26m                                                                                                           \u001b[0m\u001b[10;6H\u001b[38;2;242;244;248m\u001b[48;2;26;26;26m$ cat .env 2>/dev/null | grep -q \"HEVY_API_KEY=.\" && echo \"API_KEY_EXISTS\" || echo \"NO_API_KEY\"\u001b[0m\u001b[12;6H\u001b[38;2;242;244;248m\u001b[48;2;26;26;26mAPI_KEY_EXISTS\u001b[0m\u001b[12;20H\u001b[38;2;255;255;255m\u001b[48;2;26;26;26m                                                                                 \u001b[0m\u001b[14;3H\u001b[38;2;255;255;255m\u001b[48;2;22;22;22m                                                                                               