55;255;255m\u001b[48;2;26;26;26m     \u001b[0m\u001b[9;8H\u001b[38;2;136;136;136m\u001b[48;2;26;26;26m2\u001b[0m\u001b[9;10H\u001b[38;2;51;177;255m\u001b[48;2;26;26;26m- \u001b[0m\u001b[9;12H\u001b[38;2;255;255;255m\u001b[48;2;26;26;26m\u001b[1m**Exercise:**\u001b[0m\u001b[9;25H\u001b[38;2;242;244;248m\u001b[48;2;26;26;26m 1.5 km walk/jog\u001b[0m\u001b[10;8H\u001b[38;2;136;136;136m\u001b[48;2;26;26;26m3\u001b[0m\u001b[10;10H\u001b[38;2;51;177;255m\u001b[48;2;26;26;26m- \u001b[0m\u001b[10;12H\u001b[38;2;255;255;255m\u001b[48;2;26;26;26m\u001b[1m**Current:**\u001b[0m\u001b[10;24H\u001b[38;2;242;244;248m\u001b[48;2;26;26;26m TBD (baseline test)\u001b[0m\u001b[11;8H\u001b[38;2;136;136;136m\u001b[48;2;26;26;26m4\u001b[0m\u001b[11;14H\u001b[38;2;255;255;255m\u001b[48;2;26;26;26m\u001b[1mTarget:**\u001b[0m\u001b[11;23H\u001b[38;2;242;244;248m\u001b[48;2;26;26;26m Complete\u001b[0m\u001b[11;33H\u001b[38;2;242;244;248m\u001b[48;2;26;26;26m1.5 km in under 18 minutes\u001b[0m\u001b[12;8H\u001b[38;2;136;136;136m\u001b[48;2;26;26;26m5\u001b[0m\u001b[12;14H\u001b[38;2;255;255;255m\u001b[48;2;26;26;26m\u001b[1mDeadline:\u001b[0m\u001b[12;24H\u001b[38;2;255;255;255m\u001b[48;2;26;26;26m\u001b[1m*\u001b[0m\u001b[12;25H\u001b[38;2;242;244;248m\u001b[48;2;26;26;26m End of March\u001b[0m\u001b[12;39H\u001b[38;2;242;244;248m\u001b[48;2;26;26;26m2026\u001b[0m\u001b[12;43H\u001b[38;2;255;255;255m\u001b[48;2;26;26;26m \u001b[0m\u001b[13;8H\u001b[38;2;136;136;136m\u001b[48;2;26;26;26m6\u001b[0m\u001b[13;10H\u001b[38;2;255;255;255m\u001b[48;2;26;26;26m                                                 \u001b[0m\u001b[14;7H\u001b[38;2;255;255;255m\u001b[48;2;26;26;26m  \u001b[0m\u001b[14;10H\u001b[38;2;255;255;255m\u001b[48;2;26;26;26m                                 \u001b[0m\u001b[15;3H\u001b[38;2;255;255;255m\u001b[48;2;22;22;22m                                                                                                                                            \u001b[0m\u001b[16;3H\u0